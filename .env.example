# =============================================================================
# C&N Tecidos — Variáveis de Ambiente (EXEMPLO)
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com credenciais reais!

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://usuario:senha@host:5432/nomedobanco

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp Business API)
# -----------------------------------------------------------------------------
# URL base da Evolution API (ex: https://evolution-api.seu-dominio.com)
# EVOLUTION_API_URL=https://evolution-api.exemplo.com

# Nome da instância configurada na Evolution API
# EVOLUTION_INSTANCE=cn_tecidos

# Chave de autenticação da Evolution API
# EVOLUTION_API_KEY=sua_chave_de_autenticacao_aqui

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Chave de API para autenticação de rotas internas
# AUTHENTICATION_API_KEY=sua_chave_de_autenticacao_aqui

# -----------------------------------------------------------------------------
# Google Gemini (LLM)
# -----------------------------------------------------------------------------
# Chave da API do Google Gemini para geração de texto/imagens
# GEMINI_API_KEY=sua_chave_gemini_aqui

# -----------------------------------------------------------------------------
# Handoff (Encaminhamento para atendimento humano)
# -----------------------------------------------------------------------------
# Link de redirecionamento para atendimento humano (ex: WhatsApp, chat)
# HANDOFF_LINK=https://wa.me/5511999999999